/****************************************************************************/
/*
int KY(int y)
{
return((int) ((double)y* (double)getmaxy() /349. ));
}
*/
/****************************************************************************/
int mmx(int x)
{
 return (int) ((double)win.xa_min+(double)x/((double)MaxX / (double)win.size_xya));
}
/****************************************************************************/
int mmy(int y)
{
 return (int) ((double)win.ya_min+(double)y/((double)MaxY / (double)win.size_xya));
}

/***************************************************************************/
int DMx(long x)
{
 long tmp,t;

 t = x-(long)win.xa_min;
 tmp= (0.5 + ((double)labs(t)*((double)MaxX / (double)win.size_xya)));

 if(t< 0L) return -(int)tmp;
   else    return  (int)tmp;
}//DMx
/***************************************************************************/
int DMy(long y)
{
 long tmp,t;

 t = y-(long)win.ya_min;
 tmp= (0.5 + ((double)labs(t)*((double)MaxY / (double)win.size_xya)));

 if(t< 0L) return -(int)tmp;
   else    return  (int)tmp;
}//DMy
/***************************************************************************/
void set_attrib(void)
{
 settextstyle(pck.fnt_t,pck.dir_t,pck.siz_t);
 if(graphresult()!=0)
   {
    pck.fnt_t=DEFAULT_FONT;
   };/* if */


 setlinestyle(pck.stl_l,0,pck.thi_l);
 setfillstyle(pck.stl_f,pck.col_f);

 settextjustify(pck.hor_t,pck.ver_t);
 setcolor(pck.col_lt);

 if(mode_text == mode_text_ficx)
 {
  Multx=multx[pck.siz_t];
  Multy=multy[pck.siz_t];
 }//if

} /* set_attrib */
