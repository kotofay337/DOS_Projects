// выполнение команд рисования
int xkom_strt=100,ykom_strt=100,xkom_end=200,ykom_end=200;
int ente1;
int ente_fld;
int ente_bkgr;

int max_obj=4000;

char cnt[]={"krt"};
char lab[]={"TBG 6.00 \"TurBoGraphica\"  (C) Павельев П.И. 1991-96 /18 апреля  1996 г./\n"
            "TBG 6.02 \"TurBoGraphica\"  (C) Чумак    А.И. 1992-00 /25    jun  2000 г./"};
int xs=650,ys=360;
int oper[38];    /*место для курсора*/
int ind_move=0;

int size_str,i,x_min,x_max,y_min,y_max;
double mx; /* коэфф. масштабирования */

int komand=0;/*код команды*/

int pos=2;/* номер корректируемого параметра */
int korr_txt=0;/* необходимость корректуры текста:0-не нужно;1-нужно */

char text[SZ_text];
char s2[]={".tbg"};

char curr_file_name[80]={"c:\\demo.tbg"};

//=====================
OBJECT **FonTbg=NULL;// картинка фона TBG

LIST pic=max_obj;/* основная картинка */

char *ARGV;//указатель на строку доступа ко всем файлам редактора

extern char demomess[];

char old_ig_mode; // режим в котором была инициалицирована графика

void main(int argc,char **argv)
{
  FILE *fp;
  char s[90];
  char f1[] = {"tbgv6.pck"};
  CHAR StartFirst = ON;

  harderr((int (*)(int,int,int,int))handler);// обработчик ошибок "железа" 3.0 ?
//  harderr((int (*)())handler);// обработчик ошибок "железа" 2.0 ?
/*  sprintf(s,"%s %s",lab,demo);*/

  printf("\n%s",lab);
  if(strlen(demomess)!=0){
   printf("\nЭто %s",demomess);
   getch();/* Это ДемоВерсия */
  }/* if */

//  show(wherey()-1);
//  printf("\n");


/* выделяем путь без имени */
argc++;

//*strrchr(*argv,'\\')='\0';
// удаляем имя из строки пути с именем программы
char *ptrh;
ptrh=strrchr(*argv,'\\');

if(ptrh == 0) *argv=0;
else *ptrh=0;

ARGV=*argv;// полный путь к задаче;для текущего 0;

// ввод из файла
if((fp=fopen(f1,"rb")) != NULL)
{ /* есть файл */
 fread(&pck,sizeof(pck),1,fp);
 pck.MaxSizeKodMacro=sizeof(pck.KodMacro)/sizeof(int);
 fclose(fp);
} /* есть файл */
else getcwd(pck.div_path,MAXPATH);// нет файла - текущий каталог

if(pck.mc_index == 0)
   pck.mc_index = 1;
if(pck.mc_state == 0)
   pck.mc_state = 4;

//sprintf(s,"%s\\",*argv);/* путь к файлам BGI,CHR */
mouse_yes=ON;/* Выбрана мышь */



//long tim=biostime(0,0L);

char t[]="tbg.tbl";

// доступ к библиотеке TBL
if(ARGV == 0) sprintf(s,"%s",t);
  else sprintf(s,"%s\\%s",ARGV,t);

mperr = fopen("tbgerr.txt", "w");

set_tbl(s);

if(load_file(&menu_1,"tbg_m115.tbg") < 0) return;

if(load_file(&menu_5,"tbg_m155.tbg") < 0) return;

if(load_file(&menu_mess,"tbg_mes5.tbg") < 0) return;

//printf("\n Time load = %ld",(biostime(0,0L)-tim));
//getch();

 /* фактические цвета берем */
 col_fon1_mn1=getcolor_obj_num(menu_1,255,1);/* цвет фона для текста подсказок */
 col_fon2_mn1=getcolor_obj_num(menu_1,2,15);/* цвет фона для заданного элемента */
 col_fon3_mn1=getcolor_obj_num(menu_1,2,21);/* цвет фона для текущих значений элемента */
 col_fon4_mn1=getcolor_obj_num(menu_1,2,25);/* цвет фона для парaметров списка LE */
 col_fon5_mn1=getcolor_obj_num(menu_1,2,26);/* цвет фона для парaметров списка GE */

// sprintf(pck.Fn_work_tbg,"%s",name);//запоминаем имя файла

/*
// Перехватить Ctrl-Break
	asm cli;
	old_break =getvect(0x1b);
	setvect(0x1b,new_break );
	asm sti;
*/
#ifndef DOSX286
 registerbgifont(triplex_font);
 registerfarbgifont(simplex_font_far);
#endif

do
{

 detectgraph(&GraphDriver, &GraphMode);

 // для EGA режим наибольший допустимый
 if(GraphDriver == EGA) if(pck.ig_mode > 4) pck.ig_mode = 4;

 if(pck.ig_mode==1) {GraphDriver=CGA;GraphMode=CGAC0;pcxtype=pcxCGA_4;}// if
 if(pck.ig_mode==2) {GraphDriver=CGA;GraphMode=CGAHI;pcxtype=pcxCGA_6;}// if
 if(pck.ig_mode==3) {GraphDriver=EGA;GraphMode=EGALO;pcxtype=pcxEGA_E;}// if
 if(pck.ig_mode==4) {GraphDriver=EGA;GraphMode=EGAHI;pcxtype=pcxEGA_10;}// if
 if(pck.ig_mode==5) {GraphDriver=VGA;GraphMode=VGAHI;pcxtype=pcxVGA_12;}// if
 if(pck.ig_mode==6) {
#ifndef DOSX286
    installuserdriver("SVGA256", DetectVESA);
#endif
    GraphDriver = DETECT;
    pcxtype=pcxVGA_13;
 }// if
 if(pck.ig_mode==max_ig_mode) {GraphDriver=DETECT;}// if

// путь к файлам BGI,CHR
if(ARGV == 0) sprintf(s,"%s","");
  else        sprintf(s,"%s\\",ARGV);

// sprintf(s,"%s\\",*argv);/* путь к файлам BGI,CHR */

 initgraph(&GraphDriver, &GraphMode,s);

// gprintf("GraphDriver:%d, GraphMode:%d\n", GraphDriver, GraphMode);
// getch();


 MPCSetPath(ARGV);


 if(pck.ig_mode==max_ig_mode) { //DETECT
   // выбор режима PCX
   if( (GraphDriver==1  ) && (GraphMode==0) ) pcxtype=pcxCGA_4;
   if( (GraphDriver==1  ) && (GraphMode==4) ) pcxtype=pcxCGA_6;
   if( (GraphDriver==3  ) && (GraphMode==0) ) pcxtype=pcxEGA_E;
   if( (GraphDriver==3  ) && (GraphMode==1) ) pcxtype=pcxEGA_10;
   if( (GraphDriver==9  ) && (GraphMode==2) ) pcxtype=pcxVGA_12;
   if( (GraphDriver==134) && (GraphMode==0) ) pcxtype=pcxVGA_13;
 } // if DETECT


 mouse_ini();/*  инициализация мыши */

 mouse_mask((unsigned short int*)(markers[ARROW]),0,0);

 mouse_mode = ABSENT;

 if(GraphDriver > 10){

 // SVGA 640x480x256 OK!

 // перестроить палитру и т.д. и т.п.

 // ввести свой курсор мыши

    mouse_mode = MOUSE_ON;
/*
    while(1){
       mouse_draw();
       if(kbhit()){
          switch(getch()){
             case '1':// on
                mouse_on();
                break;
             case '2':// off
                mouse_off();
                break;
             case '0':
                goto ext;
                break;
          }/* switch */
       }/* if */
    }/* while */
    ext:;
*/
 }/* if */


 asm{
   mov ax,000fh;
   mov cx,4h;
   mov dx,7h;
   int 33h;
 }//asm

 pcxSetDisplay(pcxtype);// режим вывода PCX
 setpalette_tbg();//установка "улучшеной" палитры

 old_ig_mode=pck.ig_mode;
 pck.ig_mode=0;

 // параметры масштабирования
 win.xa_min = win.ya_min = 0;
 win.size_xya = SIZE_XY;
 //рамка для сохранения PCX
 xmin_pcx=ymin_pcx=0;
 MaxX=xmax_pcx=getmaxx();
 MaxY=ymax_pcx=getmaxy();

 if(StartFirst == ON) { // старт первый
    StartFirst = OFF;
    if(pck.Fn_work_tbg[0] != 0)
    {
       FILE *f;
       f = fopen(pck.Fn_work_tbg,"rb");
       if(f != NULL)
       {/* есть файл для загрузки */
        fclose(f);
        pic.LoadFile(pck.Fn_work_tbg);// загрузка изображения из файла
        SaveTest=OFF;// признак необходимости сохранения
        /* есть файл для загрузки */
       }/* if */
       else{pck.Fn_work_tbg[0] = 0;}/* elif */


    }// if
 }// if
/*
 {
  OBJECT **p;
  unsigned char max;
  load_file(&p,"tbg_mnw.tbg");
  getmax_obj(p,1,&max);
  printf("\n[%d]",max);
  del_pic(&p);
  getch();
 }
*/

 pck.ig_mode=painter();// вся работа

 pos_ms_pred=-1;//перевывод сообщения в меню

 closegraph();
}
while(pck.ig_mode!=NORESTART);

/*
 // восстановить Ctrl-Break.
	asm cli;
	setvect(0x1b,old_break );
	asm sti;
*/

 pck.ig_mode=old_ig_mode;// режим инициализации графики
 if(pck.mc_index == 0)
    pck.mc_index = 1;
 if(pck.mc_state == 0)
    pck.mc_state = 4;
//сохранение режимов и параметров
if((fp=fopen(f1,"wb")) != NULL)
{ /* есть файл */
 fwrite(&pck,sizeof(pck),1,fp);
 fclose(fp);
} /* есть файл */

fclose(mperr);

closegraph();

} // main

